{{> pageStart}}
<div id="contents">
				<div class="box">
					<div>
						<div class="body">
							<h1>Travel</h1>
							{{#if apiError}}
							  <p style="color:#c7a06a;">{{apiError}}</p>
							{{/if}}
							<ul id="sites">
  {{#each trips}}
    <li>
      <a href="/travel"><img src="/images/{{image}}" alt="Img"></a>
      <h2><a href="/travel">{{name}}</a></h2>
      <p>
        {{description}}
      </p>
      <p>
        <strong>Length:</strong> {{length}} &nbsp; <strong>Price:</strong> {{price}}
      </p>
    </li>
  {{/each}}
</ul>
						</div>
					</div>
				</div>
			</div>
		</div>
{{> pageEnd}}
